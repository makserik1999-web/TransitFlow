# --- TransitFlow backend config ---
# Скопируй в .env и заполни. .env в git НЕ коммитится.

# Postgres. Драйвер psycopg 3 => схема postgresql+psycopg://
# Локально с docker-compose:
DATABASE_URL=postgresql+psycopg://transitflow:transitflow@localhost:5432/transitflow
# На Railway возьми из переменной окружения сервиса Postgres
# (при необходимости поправь схему на postgresql+psycopg://).

# Секрет для подписи JWT. В проде задай длинную случайную строку.
JWT_SECRET=dev-secret-change-me

# Время жизни access-токена в минутах (опционально, по умолчанию 720).
JWT_EXPIRE_MINUTES=720

# Ключ Claude API. ОПЦИОНАЛЬНО: без него AI-сводка работает на fallback.
ANTHROPIC_API_KEY=
